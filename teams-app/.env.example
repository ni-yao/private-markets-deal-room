# The Deal Room — Teams app configuration
#
# The Teams app is a THIN INTERFACE over the shared Deal Room backend
# (the single data source). With SHARED_BACKEND_URL unset it runs in DEMO mode:
# the tab renders, but data calls return a hint until you point it at the backend.
# All variables are read in one place: server/config.js
#
# Local dev (Node >= 20.6):  node --env-file=.env server/index.js

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8090
# Public HTTPS base URL of THIS Teams app (used for manifest + card deep links).
APP_BASE_URL=

# ── Shared backend (the single data source: /api + /mcp) ──────────────────────
# Point this at YOUR running Deal Room backend (the orchestrator Container App),
# e.g. https://<your-backend-host>.<region>.azurecontainerapps.io
# Leave unset to run the Teams app in DEMO mode.
SHARED_BACKEND_URL=

# ── Interface hardening (safe-by-default) ─────────────────────────────────────
# Shared secret required to call POST /internal/notify (Adaptive Card broadcast).
# Callers must send it as the `x-internal-secret` header. When unset, the endpoint
# is only allowed in demo mode and is DISABLED once SHARED_BACKEND_URL is set.
INTERNAL_NOTIFY_SECRET=
# Allow the demo "view as" identity override on a live deployment (default off so
# role/persona cannot be spoofed). Always allowed in demo mode.
DEMO_IDENTITY_OVERRIDE=

# ── Teams tab SSO (Entra) — OBO token exchange ────────────────────────────────
ENTRA_TENANT_ID=
TEAMS_TAB_CLIENT_ID=
TEAMS_TAB_CLIENT_SECRET=

# ── Bot (Adaptive Card notifications) ─────────────────────────────────────────
BOT_APP_ID=
BOT_APP_PASSWORD=
# SingleTenant | MultiTenant | UserAssignedMSI
BOT_APP_TYPE=MultiTenant

# ── Declarative agent / MCP host (for manifest validDomains) ──────────────────
MCP_HOST=
