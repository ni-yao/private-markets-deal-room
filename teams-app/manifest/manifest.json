{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.19/MicrosoftTeams.schema.json",
  "manifestVersion": "1.19",
  "version": "0.1.0",
  "id": "<TEAMS_APP_ID>",
  "developer": {
    "name": "Private Markets Deal Room",
    "websiteUrl": "https://<TEAMS_HOST>",
    "privacyUrl": "https://<TEAMS_HOST>/privacy",
    "termsOfUseUrl": "https://<TEAMS_HOST>/terms"
  },
  "name": {
    "short": "Deal Room",
    "full": "The Deal Room"
  },
  "description": {
    "short": "AI-native private-equity deal flow in Teams.",
    "full": "A Teams channel dashboard, Adaptive Card notifications, and an M365 Copilot declarative agent for The Deal Room — all reading the same shared Deal Room backend."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#6264A7",
  "configurableTabs": [
    {
      "configurationUrl": "https://<TEAMS_HOST>/config",
      "canUpdateConfiguration": true,
      "scopes": ["team", "groupChat"],
      "context": ["channelTab"]
    }
  ],
  "staticTabs": [
    {
      "entityId": "dealroom-home",
      "name": "Deal Room",
      "contentUrl": "https://<TEAMS_HOST>/",
      "scopes": ["personal"]
    }
  ],
  "bots": [
    {
      "botId": "<BOT_APP_ID>",
      "scopes": ["team", "groupChat", "personal"],
      "supportsFiles": false,
      "isNotificationOnly": true
    }
  ],
  "copilotAgents": {
    "declarativeAgents": [
      {
        "id": "dealRoomAnalyst",
        "file": "declarativeAgent.json"
      }
    ]
  },
  "validDomains": ["<TEAMS_HOST>", "<MCP_HOST>"],
  "webApplicationInfo": {
    "id": "<TEAMS_TAB_CLIENT_ID>",
    "resource": "api://<TEAMS_HOST>/<TEAMS_TAB_CLIENT_ID>"
  }
}
