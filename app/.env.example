# The Deal Room — environment configuration
#
# Copy to `.env` and fill in only what you need. With NONE of these set the app
# runs in DEMO mode (seeded data + deterministic agents, no secrets required).
# All variables are read in one place: app/lib/config.js
#
# Local dev can load this file without extra dependencies (Node >= 20.6):
#   node --env-file=.env server.js

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
DEAL_ROOM_REGION=swedencentral
# Public base URL of this app (used to build OAuth redirect URIs). If unset the
# server derives it from the incoming request (x-forwarded-* / host).
APP_BASE_URL=

# ── Azure OpenAI / Foundry model (leave endpoint blank for demo) ──────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Optional — managed identity (DefaultAzureCredential) is preferred over a key.
AZURE_OPENAI_API_KEY=

# ── Foundry prompt agents (deal analyst + news scout) ─────────────────────────
FOUNDRY_PROJECT_ENDPOINT=
DEAL_AGENT_NAME=deal-room-analyst
DEAL_AGENT_MODEL=gpt-5-mini
NEWS_AGENT_NAME=deal-room-news-scout
NEWS_AGENT_MODEL=gpt-5-mini

# ── Cosmos DB (leave endpoint blank for in-memory demo store) ─────────────────
COSMOS_ENDPOINT=
COSMOS_DATABASE=dealroom

# ── MCP endpoint auth (Entra bearer-token validation for /mcp) ────────────────
# Required to ENFORCE auth. If MCP_AUDIENCE/ENTRA_TENANT_ID are unset and auth is
# not disabled, /mcp fails closed (503).
ENTRA_TENANT_ID=
# Comma-separated accepted audiences, e.g. "api://<clientId>,<clientId>"
MCP_AUDIENCE=
MCP_REQUIRED_SCOPE=deals.read
# "true" bypasses validation — LOCAL DEV ONLY.
MCP_AUTH_DISABLED=false

# ── Microsoft Graph change-notification webhook ───────────────────────────────
GRAPH_CLIENT_STATE=

# ── Microsoft 365 delegated connector (Teams channel provisioning) ────────────
M365_TENANT_ID=organizations
M365_CLIENT_ID=
M365_CLIENT_SECRET=
M365_TEAM_NAME=The Deal Room
M365_TEAM_ID=

# ── Data-source connectors (provider MCP servers) ─────────────────────────────
MORNINGSTAR_MCP_URL=https://mcp.morningstar.com/mcp
LSEG_MCP_URL=https://api.analytics.lseg.com/lfa/mcp
MOODYS_MCP_URL=https://mcp.moodys.com/genai-ready-data/mcp
MORNINGSTAR_CLIENT_ID=
MORNINGSTAR_CLIENT_SECRET=

# ── SEC EDGAR filings (free + keyless; needs a descriptive User-Agent) ────────
SEC_EDGAR_USER_AGENT=The Deal Room deal-room@example.com

# ── Deal workspace deep links ─────────────────────────────────────────────────
# Tenant used to build SharePoint/Teams deep links (e.g. <tenant>.sharepoint.com).
WORKSPACE_TENANT=contoso

# ── Signal ingestion ──────────────────────────────────────────────────────────
# Mailbox whose messages are treated as inbound deal-sourcing signals.
SIGNAL_INBOX=signals@example.com
